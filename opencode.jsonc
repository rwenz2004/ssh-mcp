// Test config for jump host feature: test host reachable via x86-server bastion
{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ssh-mcp": {
      "type": "local",
      "command": [
        "ssh-mcp",
        "--host=test",
        "--jump=x86-server",
        "--key=/home/ut006206@uos/.ssh/id_ed25519",
        "--timeout=60000"
      ],
      "enabled": true,
    },
  },
}
